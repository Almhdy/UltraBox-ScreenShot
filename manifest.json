{
  "manifest_version": 3,
  "name": "UltraBox Screenshot",
  "version": "1.0.0",
  "description": "A powerful screenshot tool with resizable selection, full-page, and visible-area capture modes.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "UltraBox Screenshot"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "permissions": ["activeTab", "storage", "downloads", "scripting", "tabs"],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open UltraBox Screenshot popup"
    },
    "start-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Start selection mode directly"
    }
  }
}
